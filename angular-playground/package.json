    "@angular/router": "^21.1.0",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.3",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@jsverse/transloco": "^8.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
